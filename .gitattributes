# Normalize line endings to LF on commit, checkout as-is
* text=auto eol=lf

# Explicitly LF for source files
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.json      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.md        text eol=lf

# Binary files — no line ending conversion
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.svg       binary
*.ico       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary

# Adobe CEP
*.jsx       text eol=lf
*.zxp       binary
*.p12       binary
